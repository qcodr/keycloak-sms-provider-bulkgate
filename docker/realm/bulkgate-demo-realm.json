{
  "realm": "bulkgate-demo",
  "enabled": true,
  "sslRequired": "none",
  "loginWithEmailAllowed": true,
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "cs", "da", "de", "es", "fr", "hu", "it", "lt", "lv", "pl", "pt", "ro", "sk", "sv", "uk"],
  "defaultLocale": "hu",
  "browserFlow": "bulkgate-browser",
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\": [{\"name\": \"username\", \"displayName\": \"${username}\", \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\", \"user\"]}, \"validations\": {\"length\": {\"min\": 3, \"max\": 255}, \"username-prohibited-characters\": {}, \"up-username-not-idn-homograph\": {}}}, {\"name\": \"email\", \"displayName\": \"${email}\", \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\", \"user\"]}, \"validations\": {\"email\": {}, \"length\": {\"max\": 255}}}, {\"name\": \"firstName\", \"displayName\": \"${firstName}\", \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\", \"user\"]}, \"validations\": {\"length\": {\"max\": 255}, \"person-name-prohibited-characters\": {}}}, {\"name\": \"lastName\", \"displayName\": \"${lastName}\", \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\", \"user\"]}, \"validations\": {\"length\": {\"max\": 255}, \"person-name-prohibited-characters\": {}}}, {\"name\": \"phoneNumber\", \"displayName\": \"Phone number\", \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\", \"user\"]}, \"validations\": {\"length\": {\"max\": 20}, \"pattern\": {\"pattern\": \"^\\\\+?[0-9 ()/.-]{6,}$\", \"error-message\": \"Invalid phone number\"}}}, {\"name\": \"phoneNumberVerified\", \"displayName\": \"Phone verified\", \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\"]}}]}"
          ]
        }
      }
    ]
  },
  "authenticationFlows": [
    {
      "alias": "bulkgate-browser",
      "description": "Username + password, then a BulkGate SMS one-time code.",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "authenticator": "bulkgate-sms-otp-authenticator",
          "authenticatorConfig": "bulkgate-demo-config",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 20,
          "userSetupAllowed": false
        }
      ]
    }
  ],
  "authenticatorConfig": [
    {
      "alias": "bulkgate-demo-config",
      "config": {
        "bulkgateApiUrl": "http://wiremock:8080/api/1.0/advanced/transactional",
        "simulationMode": "false",
        "bulkgateApplicationId": "demo-app",
        "bulkgateApplicationToken": "demo-token",
        "bulkgateSenderId": "gText",
        "bulkgateSenderIdValue": "Keycloak",
        "codeLength": "6",
        "codeTtlSeconds": "300",
        "maxVerifyAttempts": "3",
        "resendCooldownSeconds": "30",
        "maxResends": "3",
        "phoneNumberAttribute": "phoneNumber",
        "defaultCountryCode": "+36"
      }
    }
  ],
  "clients": [
    {
      "clientId": "demo-client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Demo",
      "realmRoles": [
        "default-roles-bulkgate-demo"
      ],
      "attributes": {
        "phoneNumber": [
          "+36201234567"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}
